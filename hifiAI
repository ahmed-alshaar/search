<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        window.FontAwesomeConfig = {
          autoReplaceSvg: 'nest'
        };
      </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Search Interface</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        cyber: {
                            base: '#121212',
                            card: '#1A1A2E',
                            cardHover: '#252839',
                            violet: '#8A2BE2',
                            violetGlow: 'rgba(138, 43, 226, 0.5)',
                            emerald: '#50C878',
                            emeraldGlow: 'rgba(80, 200, 120, 0.4)',
                            text: '#F2F2F2',
                            textMuted: '#94969F',
                            border: '#2A2A35'
                        }
                    },
                    backgroundImage: {
                        'cyber-gradient': 'linear-gradient(180deg, #121212 0%, #1A1A2E 100%)',
                        'card-gradient': 'linear-gradient(145deg, #1E1E21 0%, #121212 100%)',
                    },
                    boxShadow: {
                        'neon-violet': '0 0 15px rgba(138, 43, 226, 0.3)',
                        'neon-emerald': '0 4px 20px rgba(80, 200, 120, 0.4)',
                        'card-inset': 'inset 0 1px 0 rgba(255, 255, 255, 0.05)',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #121212;
            color: #F2F2F2;
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
            overflow: hidden;
            position: fixed;
            width: 100%;
            height: 100vh;
            height: 100dvh;
        }
        ::-webkit-scrollbar { display: none; }
        
        .glass-panel {
            background: rgba(26, 26, 46, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(138, 43, 226, 0.2);
        }
        
        .hex-bg {
            background-image: radial-gradient(rgba(138, 43, 226, 0.15) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        .scanlines::before {
            content: " ";
            display: block;
            position: absolute;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 2;
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
        }
        
        .chip-active {
            background-color: rgba(138, 43, 226, 0.2);
            border-color: #8A2BE2;
            color: #F2F2F2;
            box-shadow: 0 0 10px rgba(138, 43, 226, 0.3);
        }
        
        .message-bubble-user {
            background: rgba(42, 42, 53, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px 16px 4px 16px;
        }
        
        .message-bubble-ai {
            background: rgba(138, 43, 226, 0.1);
            border: 1px solid rgba(138, 43, 226, 0.3);
            border-radius: 16px 16px 16px 4px;
            box-shadow: 0 4px 20px rgba(138, 43, 226, 0.1);
        }

        #mobile-container {
            height: 100vh;
            height: 100dvh;
            overflow: hidden;
        }

        #chat-scroll-area {
            overflow-y: auto;
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

        #chat-scroll-area::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="bg-cyber-base">

    <!-- Background Effects -->
    <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] left-[-20%] w-[80%] h-[60%] bg-cyber-violet opacity-15 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[70%] h-[70%] bg-[#3F51B5] opacity-10 blur-[100px] rounded-full"></div>
        <div class="absolute inset-0 hex-bg z-0"></div>
        <div class="absolute inset-0 scanlines opacity-30"></div>
    </div>

    <!-- Main Mobile Container -->
    <main id="mobile-container" class="w-full max-w-[375px] flex flex-col relative z-10 mx-auto bg-cyber-base md:max-w-md lg:max-w-lg xl:max-w-xl">
        
        <!-- Header Shell -->
        <header id="header" class="flex items-center justify-between w-full px-6 py-4 relative z-20 border-b border-cyber-border bg-cyber-base/80 backdrop-blur-md flex-shrink-0">
            <div class="flex items-center space-x-3">
                <div class="w-8 h-8 rounded-full bg-cyber-violet/20 border border-cyber-violet flex items-center justify-center shadow-[0_0_10px_rgba(138,43,226,0.3)]">
                    <i class="fa-solid fa-robot text-cyber-violet text-sm"></i>
                </div>
                <div>
                    <h1 class="text-white font-bold text-sm">AI Intelligence</h1>
                    <p class="text-cyber-violet text-[10px] font-mono flex items-center gap-1">
                        <span class="w-1.5 h-1.5 rounded-full bg-cyber-violet shadow-[0_0_5px_#8A2BE2] animate-pulse"></span>
                        Online
                    </p>
                </div>
            </div>
            <button class="w-10 h-10 rounded-xl glass-panel flex items-center justify-center text-cyber-textMuted hover:text-white transition-colors">
                <i class="fa-solid fa-clock-rotate-left text-sm"></i>
            </button>
        </header>

        <!-- Chat Area Scrollable -->
        <div id="chat-scroll-area" class="flex-1 px-4 py-6 space-y-6">
            
            <!-- Date Divider -->
            <div class="flex justify-center">
                <span class="text-[10px] font-mono text-cyber-textMuted bg-cyber-card/50 px-3 py-1 rounded-full border border-cyber-border">Today, 14:23</span>
            </div>

            <!-- User Message 1 -->
            <div class="flex justify-end w-full pl-12">
                <div class="message-bubble-user p-3.5 max-w-full relative">
                    <p class="text-sm text-white leading-relaxed">I'm looking for games like Hades, but with a sci-fi theme. Something fast-paced with good replayability.</p>
                </div>
            </div>

            <!-- AI Response 1 - Typing Indicator -->
            <div class="flex justify-start w-full pr-12 hidden" id="typing-indicator">
                <div class="flex items-start gap-2">
                    <div class="w-6 h-6 rounded-full bg-cyber-violet/20 border border-cyber-violet flex items-center justify-center shrink-0 mt-1">
                        <i class="fa-solid fa-robot text-[10px] text-cyber-violet"></i>
                    </div>
                    <div class="message-bubble-ai p-3.5 flex items-center gap-1.5">
                        <div class="w-1.5 h-1.5 bg-cyber-violet rounded-full animate-bounce" style="animation-delay: 0ms"></div>
                        <div class="w-1.5 h-1.5 bg-cyber-violet rounded-full animate-bounce" style="animation-delay: 150ms"></div>
                        <div class="w-1.5 h-1.5 bg-cyber-violet rounded-full animate-bounce" style="animation-delay: 300ms"></div>
                    </div>
                </div>
            </div>

            <!-- AI Response 1 - Structured Content -->
            <div class="flex justify-start w-full pr-4">
                <div class="flex items-start gap-2 w-full">
                    <div class="w-6 h-6 rounded-full bg-cyber-violet/20 border border-cyber-violet flex items-center justify-center shrink-0 mt-1 shadow-[0_0_8px_rgba(138,43,226,0.4)]">
                        <i class="fa-solid fa-robot text-[10px] text-cyber-violet"></i>
                    </div>
                    <div class="w-full space-y-3">
                        <div class="message-bubble-ai p-3.5">
                            <p class="text-sm text-white leading-relaxed mb-3">Excellent choice. Fast-paced isometric combat in a sci-fi setting is a great subgenre. I've analyzed your playstyle (high difficulty preference, short sessions) and found these top matches:</p>
                            
                            <!-- Follow-up Filter Chips -->
                            <div class="flex flex-wrap gap-2 mt-2">
                                <button class="px-2.5 py-1 rounded-md text-[10px] font-mono border border-cyber-border text-cyber-textMuted bg-cyber-card hover:border-cyber-violet/50 transition-all flex items-center gap-1.5">
                                    <i class="fa-solid fa-gamepad"></i> Platform
                                </button>
                                <button class="px-2.5 py-1 rounded-md text-[10px] font-mono border border-cyber-border text-cyber-textMuted bg-cyber-card hover:border-cyber-violet/50 transition-all flex items-center gap-1.5">
                                    <i class="fa-solid fa-users"></i> Co-op
                                </button>
                                <button class="px-2.5 py-1 rounded-md text-[10px] font-mono border border-cyber-violet text-white bg-cyber-violet/20 shadow-[0_0_10px_rgba(138,43,226,0.3)] transition-all flex items-center gap-1.5">
                                    <i class="fa-solid fa-fire"></i> High Difficulty
                                </button>
                            </div>
                        </div>

                        <!-- Game Result Card 1 -->
                        <div class="glass-panel rounded-xl overflow-hidden border border-cyber-violet/40 shadow-[0_4px_20px_rgba(138,43,226,0.15)] group relative">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-cyber-violet opacity-20 blur-[40px] rounded-bl-full pointer-events-none"></div>
                            
                            <!-- Card Header Image -->
                            <div class="h-28 w-full relative">
                                <div class="absolute inset-0 bg-gradient-to-t from-cyber-card to-transparent z-10"></div>
                                <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/350e856db0-0628126c2dcee85c4136.png" alt="Isometric cyberpunk roguelike game screenshot, neon lighting, dark metallic floors, glowing projectiles, highly detailed sci-fi action" />
                                
                                <div class="absolute top-2 left-2 z-20 bg-cyber-base/90 backdrop-blur-md border border-cyber-violet px-2 py-1 rounded-md flex items-center gap-1.5 shadow-[0_0_10px_rgba(138,43,226,0.3)]">
                                    <i class="fa-solid fa-fingerprint text-cyber-violet text-[10px]"></i>
                                    <span class="text-white text-xs font-bold font-mono">96% Match</span>
                                </div>
                                
                                <button class="absolute top-2 right-2 z-20 w-8 h-8 bg-cyber-base/80 backdrop-blur-md border border-cyber-border rounded-full flex items-center justify-center text-cyber-textMuted hover:text-white hover:border-cyber-emerald transition-all">
                                    <i class="fa-regular fa-bookmark text-xs"></i>
                                </button>
                            </div>
                            
                            <div class="p-3.5 relative z-20 -mt-6">
                                <div class="flex justify-between items-end mb-2">
                                    <h3 class="text-white font-bold text-base">Synthetik: Legion Rising</h3>
                                    <span class="text-cyber-emerald text-[10px] font-mono border border-cyber-emerald/30 bg-cyber-emerald/10 px-1.5 py-0.5 rounded flex items-center gap-1">
                                        <i class="fa-solid fa-bolt"></i> +450 IP
                                    </span>
                                </div>
                                
                                <!-- DNA Tags -->
                                <div class="flex flex-wrap gap-1.5 mb-3">
                                    <span class="text-[9px] text-cyber-textMuted border border-cyber-border bg-cyber-base/50 px-1.5 py-0.5 rounded">Roguelite</span>
                                    <span class="text-[9px] text-cyber-textMuted border border-cyber-border bg-cyber-base/50 px-1.5 py-0.5 rounded">Top-Down Shooter</span>
                                    <span class="text-[9px] text-cyber-violet border border-cyber-violet/30 bg-cyber-violet/10 px-1.5 py-0.5 rounded">Brutal Difficulty</span>
                                </div>

                                <!-- Why This Match -->
                                <div class="bg-cyber-base/60 border border-cyber-border/50 rounded-lg p-2.5 mb-3">
                                    <p class="text-[11px] text-cyber-textMuted leading-snug">
                                        <span class="text-cyber-violet font-semibold"><i class="fa-solid fa-sparkles text-[9px] mr-1"></i>Why it matches:</span> Replicates the dash-and-strike rhythm of Hades but swaps mythology for relentless cybernetic gunplay. Runs average 20-40 mins.
                                    </p>
                                </div>
                                
                                <!-- Actions -->
                                <div class="flex gap-2">
                                    <button class="flex-1 bg-cyber-card border border-cyber-violet text-white font-semibold text-xs py-2 rounded-lg hover:bg-cyber-violet/20 transition-colors">
                                        View Details
                                    </button>
                                    <button class="flex-1 bg-cyber-emerald hover:bg-[#45b56a] text-cyber-base font-bold text-xs py-2 rounded-lg shadow-[0_0_15px_rgba(80,200,120,0.3)] transition-transform active:scale-95 flex items-center justify-center gap-1.5">
                                        <i class="fa-solid fa-play text-[10px]"></i> Add to Quest
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Game Result Card 2 -->
                        <div class="glass-panel rounded-xl overflow-hidden border border-cyber-border shadow-sm group relative">
                            <div class="h-24 w-full relative">
                                <div class="absolute inset-0 bg-gradient-to-t from-cyber-card to-transparent z-10"></div>
                                <img class="w-full h-full object-cover" src="https://storage.googleapis.com/uxpilot-auth.appspot.com/0aeaf32adf-c59db6b63d49f2e92089.png" alt="Sci-fi action game top down view, dark futuristic spaceship interior, glowing blue and orange weapons, intense combat" />
                                
                                <div class="absolute top-2 left-2 z-20 bg-cyber-base/90 backdrop-blur-md border border-cyber-border px-2 py-1 rounded-md flex items-center gap-1.5">
                                    <i class="fa-solid fa-fingerprint text-cyber-textMuted text-[10px]"></i>
                                    <span class="text-white text-xs font-bold font-mono">89% Match</span>
                                </div>
                            </div>
                            
                            <div class="p-3.5 relative z-20 -mt-5">
                                <div class="flex justify-between items-end mb-2">
                                    <h3 class="text-white font-bold text-[15px]">Ruiner</h3>
                                    <span class="text-cyber-emerald text-[10px] font-mono border border-cyber-emerald/30 bg-cyber-emerald/10 px-1.5 py-0.5 rounded flex items-center gap-1">
                                        <i class="fa-solid fa-bolt"></i> +200 IP
                                    </span>
                                </div>
                                
                                <div class="flex flex-wrap gap-1.5 mb-2">
                                    <span class="text-[9px] text-cyber-textMuted border border-cyber-border bg-cyber-base/50 px-1.5 py-0.5 rounded">Story-Rich</span>
                                    <span class="text-[9px] text-cyber-textMuted border border-cyber-border bg-cyber-base/50 px-1.5 py-0.5 rounded">Cyberpunk</span>
                                </div>

                                <div class="bg-cyber-base/60 border border-cyber-border/50 rounded-lg p-2.5 mb-3">
                                    <p class="text-[11px] text-cyber-textMuted leading-snug truncate">
                                        <span class="text-white font-semibold">Match Insight:</span> Incredible aesthetic and fast melee/dash combat. Less roguelike, more linear narrative.
                                    </p>
                                </div>
                                
                                <button class="w-full bg-cyber-card border border-cyber-border text-cyber-textMuted hover:text-white hover:border-cyber-violet font-semibold text-xs py-2 rounded-lg transition-colors">
                                    View Details
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Bottom spacing for input area -->
            <div class="h-40"></div>

        </div>

        <!-- Sticky Input Area -->
        <div class="fixed bottom-16 left-0 right-0 max-w-[375px] mx-auto p-4 bg-gradient-to-t from-cyber-base via-cyber-base to-transparent z-30 pt-10 md:max-w-md lg:max-w-lg xl:max-w-xl">
            <div class="glass-panel rounded-2xl p-2 border border-cyber-violet/30 shadow-[0_0_20px_rgba(138,43,226,0.1)] relative">
                <div class="absolute -top-3 left-4 flex gap-2">
                    <span class="bg-cyber-card border border-cyber-border text-cyber-textMuted text-[9px] font-mono px-2 py-0.5 rounded-full flex items-center gap-1">
                        <i class="fa-solid fa-wand-magic-sparkles text-cyber-violet"></i> AI Enhanced
                    </span>
                </div>
                
                <textarea 
                    class="w-full bg-transparent text-white text-sm placeholder-cyber-textMuted/50 border-none outline-none resize-none p-2 min-h-[44px] max-h-[120px]" 
                    placeholder="Ask for more recommendations, refine by platform, or request specific mechanics..."
                    rows="1"
                ></textarea>
                
                <div class="flex items-center justify-between mt-1 px-1 pb-1">
                    <div class="flex gap-1">
                        <button class="w-8 h-8 rounded-lg flex items-center justify-center text-cyber-textMuted hover:text-white hover:bg-cyber-card transition-colors">
                            <i class="fa-solid fa-microphone text-xs"></i>
                        </button>
                        <button class="w-8 h-8 rounded-lg flex items-center justify-center text-cyber-textMuted hover:text-white hover:bg-cyber-card transition-colors">
                            <i class="fa-solid fa-sliders text-xs"></i>
                        </button>
                    </div>
                    <button class="w-8 h-8 rounded-lg bg-cyber-violet/20 border border-cyber-violet text-cyber-violet flex items-center justify-center hover:bg-cyber-violet hover:text-white transition-all shadow-[0_0_10px_rgba(138,43,226,0.2)]">
                        <i class="fa-solid fa-paper-plane text-xs"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Bottom Navigation Shell -->
        <nav id="bottom-nav" class="fixed bottom-0 left-0 right-0 max-w-[375px] mx-auto h-16 bg-cyber-base/95 backdrop-blur-xl border-t border-cyber-border z-40 px-6 flex items-center justify-between flex-shrink-0 md:max-w-md lg:max-w-lg xl:max-w-xl">
            <a href="#" class="flex flex-col items-center gap-1 text-cyber-textMuted hover:text-white transition-colors">
                <i class="fa-solid fa-compass text-lg"></i>
                <span class="text-[8px] font-mono">Discover</span>
            </a>
            
            <a href="#" class="flex flex-col items-center gap-1 text-cyber-violet relative group">
                <i class="fa-solid fa-magnifying-glass text-lg"></i>
                <span class="text-[8px] font-mono font-bold">AI Search</span>
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-cyber-violet shadow-[0_0_8px_#8A2BE2]"></div>
            </a>
            
            <a href="#" class="flex flex-col items-center gap-1 text-cyber-textMuted hover:text-white transition-colors relative">
                <div class="absolute -top-1 -right-1 w-2 h-2 bg-cyber-emerald rounded-full border border-cyber-base"></div>
                <i class="fa-solid fa-crosshairs text-lg"></i>
                <span class="text-[8px] font-mono">Quests</span>
            </a>
            
            <a href="#" class="flex flex-col items-center gap-1 text-cyber-textMuted hover:text-white transition-colors">
                <i class="fa-solid fa-layer-group text-lg"></i>
                <span class="text-[8px] font-mono">Library</span>
            </a>
            
            <a href="#" class="flex flex-col items-center gap-1 text-cyber-textMuted hover:text-white transition-colors">
                <i class="fa-solid fa-user text-lg"></i>
                <span class="text-[8px] font-mono">Profile</span>
            </a>
        </nav>

    </main>
</body>
</html>
